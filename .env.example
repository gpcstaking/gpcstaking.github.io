PRIVATE_KEY=
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSCSCAN_API_KEY=
ALLOW_MAINNET_DEPLOY=no

# Temporary testing mode only: lets the deployment EOA own both ProxyAdmin contracts.
ALLOW_TEMPORARY_EOA_ADMIN=no

# Deployed six-hour TWAP oracle proxy used by updates and the mining initializer.
ORACLE_ADDRESS=

# Separate TimelockController contracts. Each must have at least a 48-hour delay
# and should be controlled by a different Safe/multisig.
ORACLE_TIMELOCK_OWNER=
MINING_TIMELOCK_OWNER=

# Required only when preparing a later implementation upgrade.
MINING_PROXY_ADDRESS=

# Optional encoded reinitializer call for prepare-upgrade scripts; leave 0x when none is needed.
UPGRADE_CALLDATA=0x

# Optional TimelockController operation identifiers. Defaults are safe for an independent upgrade.
# Set a predecessor only when this upgrade must execute after another scheduled operation.
TIMELOCK_PREDECESSOR=
TIMELOCK_SALT=
